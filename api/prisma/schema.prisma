generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attribute {
  id          Int         @id @default(autoincrement())
  name        String
  description String
  challenges  Challenge[]
  entityAttributes TitleRequirement[]
  playerAttributeScores PlayerAttributeScore[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([name])
}

model Player {
  id                    Int                    @id @default(autoincrement())
  name                  String?
  playerCode            String                 @unique
  challengeParticipation ChallengeParticipant[]
  playerAttributeScores PlayerAttributeScore[]
  events                GameEventPlayer[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model GameEvent {
  id                    Int                    @id @default(autoincrement())
  name                  String
  description           String
  current               Boolean                @default(false)
  players               GameEventPlayer[]
  challengeInstances    ChallengeInstance[]
  playerAttributeScores PlayerAttributeScore[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model GameEventPlayer {
  id        Int      @id @default(autoincrement())
  eventId   Int
  playerId  Int
  event     GameEvent    @relation(fields: [eventId], references: [id])
  player    Player   @relation(fields: [playerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, playerId])
}

model PlayerAttributeScore {
  id          Int       @id @default(autoincrement())
  playerId    Int
  attributeId Int
  eventId     Int
  score       Int       @default(0)
  player      Player    @relation(fields: [playerId], references: [id])
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  event       GameEvent     @relation(fields: [eventId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([playerId, attributeId, eventId])
}


model Challenge {
  id          Int                 @id @default(autoincrement())
  description String
  score       Int
  type        ChallengeType       @default(SOLO)
  custom      Boolean             @default(false)
  attributeId Int
  attribute   Attribute           @relation(fields: [attributeId], references: [id])
  instances   ChallengeInstance[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

enum ChallengeType {
  SOLO
  ADVERSARIAL
}

enum ChallengeStatus {
  OPEN
  COMPLETED
  FAILED
}

model ChallengeInstance {
  id           Int                    @id @default(autoincrement())
  challengeId  Int
  eventId      Int
  challenge    Challenge              @relation(fields: [challengeId], references: [id])
  event        GameEvent              @relation(fields: [eventId], references: [id])
  participants ChallengeParticipant[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model ChallengeParticipant {
  id         Int               @id @default(autoincrement())
  playerId   Int
  instanceId Int
  status     ChallengeStatus   @default(OPEN)
  player     Player            @relation(fields: [playerId], references: [id])
  instance   ChallengeInstance @relation(fields: [instanceId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([playerId, instanceId])
}

enum TitleType {
  SINGLE_REQUIREMENT
  MULTI_REQUIREMENT_AVERAGE
}

model Title {
  id            Int               @id @default(autoincrement())
  name          String
  imageUrl      String?
  description   String
  requirements  TitleRequirement[]
  titleType     TitleType
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model TitleRequirement {
  id          Int       @id @default(autoincrement())
  titleId     Int
  attributeId Int
  title       Title    @relation(fields: [titleId], references: [id])
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  threshold   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([titleId, attributeId])
}